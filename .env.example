# Nexus AI Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# OpenAI Configuration
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096

# ============================================
# Application Configuration
# ============================================
DEBUG=false
LOG_LEVEL=INFO
ENVIRONMENT=production

# ============================================
# Server Configuration
# ============================================
HOST=0.0.0.0
PORT=8000

# ============================================
# Frontend & Backend URLs (for CORS)
# ============================================
FRONTEND_URL=https://nexus-ai.vercel.app
BACKEND_URL=https://nexus-ai-backend.onrender.com

# ============================================
# Vercel Deployment
# ============================================
# Add your Vercel project URL here after deployment
# VERCEL_PROJECT_URL=https://nexus-ai.vercel.app

# ============================================
# Render Deployment
# ============================================
# Add your Render backend URL here after deployment
# RENDER_BACKEND_URL=https://nexus-ai-backend.onrender.com

# ============================================
# Sandbox Configuration
# ============================================
MAX_RETRIES=5
SANDBOX_TIMEOUT=30

# ============================================
# Next.js Configuration (Frontend)
# ============================================
NEXT_PUBLIC_OPENAI_API_KEY=sk-your-openai-api-key-here
NEXT_PUBLIC_BACKEND_URL=https://nexus-ai-backend.onrender.com
NEXT_PUBLIC_FRONTEND_URL=https://nexus-ai.vercel.app