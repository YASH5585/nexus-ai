# Nexus AI Backend Environment Variables
# Copy this file to .env and fill in your values

# OpenAI API Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096

# HuggingFace Configuration (free alternative)
HUGGINGFACE_API_KEY=your-free-huggingface-token-here
HUGGINGFACE_MODEL=google/flan-t5-large
LLM_PROVIDER=huggingface

# Application Configuration
DEBUG=false
LOG_LEVEL=INFO
ENVIRONMENT=production

# Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS Configuration (comma-separated URLs)
FRONTEND_URL=https://nexus-ai.vercel.app
BACKEND_URL=https://nexus-ai-backend.onrender.com
CORS_ORIGINS=https://nexus-ai.vercel.app,https://*.vercel.app

# Additional Settings
MAX_RETRIES=5
SANDBOX_TIMEOUT=30